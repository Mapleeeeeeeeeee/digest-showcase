---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { POST_CATEGORIES } from "../content.config";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const ALL_FILTER = "全部";
const filters = [ALL_FILTER, ...POST_CATEGORIES];

const FILTER_ICONS: Record<string, string> = {
  '全部': 'grid_view',
  '知識精華': 'lightbulb',
  '社群活動': 'groups',
};
---

<BaseLayout
  title="Claude Taiwan 社團精華展示櫃"
  description="精選 Claude Taiwan Facebook 社團的知識精華與社群活動分享。"
>
  <section class="container intro">
    <h2 class="intro__heading">精華展示櫃</h2>
    <p class="intro__lead">
      收藏 Claude Taiwan 社團裡值得一看再看的分享 —— 從 AI 協作開發、工具實作到社群活動紀錄。
    </p>

    <div class="filter-bar">
      <div class="filters" role="group" aria-label="依分類篩選">
        {
          filters.map((filter, index) => (
            <button
              type="button"
              class="filter-chip"
              class:list={[{ "filter-chip--active": index === 0 }]}
              data-filter={filter}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {FILTER_ICONS[filter] && (
                <span class="material-symbols-outlined filter-chip__icon" aria-hidden="true">
                  {FILTER_ICONS[filter]}
                </span>
              )}
              {filter}
            </button>
          ))
        }
      </div>
      <div class="view-toggle" role="group" aria-label="切換顯示模式">
        <button type="button" class="view-toggle__btn view-toggle__btn--active" data-view="grid" aria-pressed="true">
          <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
        </button>
        <button type="button" class="view-toggle__btn" data-view="list" aria-pressed="false">
          <span class="material-symbols-outlined" aria-hidden="true">view_list</span>
        </button>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="grid" id="post-grid">
      {posts.map((post, index) => (
        <div class="reveal" style={`--i: ${index}`}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
    <p class="empty" id="empty-state" hidden>此分類目前沒有貼文。</p>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: 40px;
  }

  .intro__heading {
    margin: 0 0 8px;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: 0.01em;
  }

  .intro__lead {
    margin: 0 0 24px;
    max-width: 60ch;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .filter-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 8px 18px;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .filter-chip__icon {
    font-size: 16px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
    line-height: 1;
  }

  .filter-chip--active .filter-chip__icon {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 20;
  }

  .filter-chip:hover:not(.filter-chip--active) {
    color: var(--color-text);
    border-color: var(--color-primary-light);
  }

  .filter-chip--active:hover {
    background: var(--color-primary-dark);
  }

  .filter-chip--active {
    color: #fff;
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 22px;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 48px 0;
  }

  .view-toggle {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .view-toggle__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-family: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    color: var(--color-text-muted);
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .view-toggle__btn .material-symbols-outlined {
    font-size: 20px;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
    line-height: 1;
  }

  .view-toggle__btn:hover:not(.view-toggle__btn--active) {
    color: var(--color-text);
    border-color: var(--color-primary-light);
  }

  .view-toggle__btn--active {
    color: #fff;
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .view-toggle__btn--active .material-symbols-outlined {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 20;
  }

  .view-toggle__btn--active:hover {
    background: var(--color-primary-dark);
  }

  .grid--list {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Client-side category filter for this prototype: toggles card visibility by
  // the data-category attribute. No framework — runs after the page loads.
  const ALL_FILTER = "全部";
  const ACTIVE_CLASS = "filter-chip--active";

  const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
  const cards = document.querySelectorAll<HTMLElement>("[data-category]");
  const emptyState = document.getElementById("empty-state");

  function applyFilter(selected: string): void {
    let visibleCount = 0;
    cards.forEach((card) => {
      const matches =
        selected === ALL_FILTER || card.dataset.category === selected;
      const wrapper = card.closest('.reveal') as HTMLElement | null;
      const target = wrapper ?? card;
      target.hidden = !matches;
      if (matches) {
        visibleCount += 1;
        if (wrapper) {
          wrapper.style.animation = 'none';
          wrapper.offsetHeight; // force reflow
          wrapper.style.animation = 'fadeIn 0.3s ease both';
        }
      }
    });
    if (emptyState) emptyState.hidden = visibleCount > 0;
  }

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((other) => {
        const isActive = other === chip;
        other.classList.toggle(ACTIVE_CLASS, isActive);
        other.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
      applyFilter(chip.dataset.filter ?? ALL_FILTER);
    });
  });

  // Scroll reveal: fade in cards as they enter the viewport
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

  // View toggle: switch between grid and list layout
  const VIEW_ACTIVE_CLASS = "view-toggle__btn--active";
  const LIST_CLASS = "grid--list";

  const viewBtns = document.querySelectorAll<HTMLButtonElement>(".view-toggle__btn");
  const postGrid = document.getElementById("post-grid");

  viewBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      viewBtns.forEach((other) => {
        const isActive = other === btn;
        other.classList.toggle(VIEW_ACTIVE_CLASS, isActive);
        other.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
      postGrid?.classList.toggle(LIST_CLASS, btn.dataset.view === "list");
    });
  });
</script>
