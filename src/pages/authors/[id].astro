---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { buildUrl } from "../../lib/url";
import BackLink from "../../components/BackLink.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("posts");

  const authorMap = new Map<
    string,
    { author: string; authorUrl: string; posts: typeof posts }
  >();

  posts.forEach((post) => {
    const { authorId, author, authorUrl } = post.data;
    if (!authorMap.has(authorId)) {
      authorMap.set(authorId, { author, authorUrl, posts: [] });
    }
    authorMap.get(authorId)!.posts.push(post);
  });

  return Array.from(authorMap.entries()).map(([id, data]) => ({
    params: { id },
    props: {
      authorName: data.author,
      authorUrl: data.authorUrl,
      posts: data.posts.sort(
        (a, b) => b.data.date.getTime() - a.data.date.getTime(),
      ),
    },
  }));
}) satisfies GetStaticPaths;

const { authorName, authorUrl, posts } = Astro.props;
const homeHref = buildUrl("/");
---

<BaseLayout title={`${authorName} · Claude Taiwan 社團精華展示櫃`}>
  <section class="container author">
    <BackLink href={homeHref} />

    <header class="author__header">
      <div class="author__avatar" aria-hidden="true">
        {authorName.slice(0, 1)}
      </div>
      <div>
        <h1 class="author__name">{authorName}</h1>
        <p class="author__stat">{posts.length} 篇精選貼文</p>
      </div>
    </header>

    <a
      href={authorUrl}
      class="author__fb-link"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="material-symbols-outlined" aria-hidden="true">open_in_new</span>
      前往 Facebook 個人檔案
    </a>

    <h2 class="author__section-title">精選貼文</h2>

    {
      posts.length > 0 ? (
        <div class="author__grid">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="author__empty">這位作者目前沒有精選貼文。</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .author {
    max-width: 760px;
    padding-top: 32px;
  }

  .author__header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .author__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 700;
    flex: none;
  }

  .author__name {
    margin: 0;
    font-size: clamp(1.4rem, 4vw, 1.8rem);
    font-weight: 800;
    line-height: 1.3;
  }

  .author__stat {
    margin: 4px 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .author__fb-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-surface);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 10px 20px;
    border: 1px solid var(--color-primary-light);
    border-radius: 999px;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
    margin-bottom: 36px;
  }

  .author__fb-link:hover {
    background: var(--color-primary-subtle);
    border-color: var(--color-primary);
  }

  .author__fb-link .material-symbols-outlined {
    font-size: 18px;
  }

  .author__section-title {
    margin: 36px 0 20px;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .author__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 22px;
  }

  .author__empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 48px 0;
  }

  @media (max-width: 560px) {
    .author__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
