---
import type { CollectionEntry } from "astro:content";
import CategoryBadge from "./CategoryBadge.astro";
import PostStats from "./PostStats.astro";
import { getThumbnail } from "../lib/images";
import { formatDateZh } from "../lib/format";
import { postUrl, buildUrl, authorUrl } from "../lib/url";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { data } = post;
const thumbnail = getThumbnail(data.images);
const href = postUrl(post.id);
const formattedDate = formatDateZh(data.date);
const sparkSrc = buildUrl("/spark-static.svg");
const authorHref = authorUrl(data.authorId);
---

<article class="card" data-category={data.category} data-post-type={data.postType}>
  <a href={href} class="card__media-link" aria-label={data.title}>
    <div class="card__media">
      {
        thumbnail ? (
          <img
            class="card__thumb"
            src={thumbnail}
            alt={data.title}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="card__placeholder" aria-hidden="true">
            <img src={sparkSrc} alt="" class="card__placeholder-icon" />
            <span>文字分享</span>
          </div>
        )
      }
      <span class="card__badge">
        {data.postType === "discussion" ? (
          <span class="card__type-badge card__type-badge--discussion">
            <span class="material-symbols-outlined" style="font-size:12px">forum</span>
            留言精華
          </span>
        ) : data.postType === "qa" ? (
          <span class="card__type-badge card__type-badge--qa">
            <span class="material-symbols-outlined" style="font-size:12px">help</span>
            常見問題
          </span>
        ) : (
          <CategoryBadge category={data.category} />
        )}
      </span>
    </div>
  </a>

  <div class="card__body">
    <h2 class="card__title">
      <a href={href} class="card__title-link">{data.title}</a>
    </h2>
    <p class="card__meta">
      <a
        href={authorHref}
        class="card__author-link"
      >
        {data.author}
      </a> · {formattedDate}
    </p>
    <div class="card__footer">
      <PostStats likes={data.likes} comments={data.comments} shares={data.shares} />
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-primary-light);
  }

  .card__media-link {
    display: block;
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--color-primary-subtle);
    overflow: hidden;
  }

  .card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card:hover .card__thumb {
    transform: scale(1.05);
  }

  .card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--color-primary);
    background:
      radial-gradient(circle at 50% 45%, var(--color-primary-subtle), transparent 70%),
      var(--color-surface-alt);
  }

  .card__placeholder-icon {
    width: 48px;
    height: 48px;
    opacity: 0.6;
  }

  .card__placeholder span {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .card__type-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.68rem;
    font-weight: 600;
    border-radius: 999px;
    padding: 3px 8px;
    line-height: 1.4;
    white-space: nowrap;
  }

  .card__type-badge--discussion {
    color: #1565c0;
    background: #e3f2fd;
  }

  .card__type-badge--qa {
    color: #e65100;
    background: #fff3e0;
  }

  .card__body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .card__title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.5;
    /* Clamp long titles to keep cards even. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__title-link {
    color: inherit;
  }

  .card__title-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card__title-link:hover {
    color: var(--color-primary);
  }

  .card__meta {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .card__author-link {
    position: relative;
    z-index: 1;
    color: var(--color-primary);
    font-weight: 600;
  }

  .card__author-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .card__footer {
    margin-top: auto;
    padding-top: 6px;
  }

  /* List mode overrides */
  :global(.grid--list) .card {
    flex-direction: row;
    height: auto;
  }

  :global(.grid--list) .card:hover {
    transform: translateY(-2px);
  }

  :global(.grid--list) .card__media-link {
    flex-shrink: 0;
  }

  :global(.grid--list) .card__media {
    width: 120px;
    min-width: 120px;
    aspect-ratio: 1;
  }

  :global(.grid--list) .card__body {
    padding: 12px 16px;
  }

  :global(.grid--list) .card__title {
    font-size: 0.95rem;
    -webkit-line-clamp: 1;
  }

  :global(.grid--list) .card__badge {
    top: 8px;
    left: 8px;
  }
</style>
